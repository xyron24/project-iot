    {
        "id": "63f5e930bd7881fe",
        "type": "function",
        "z": "6cc23e5bb2cb7ac2",
        "name": "Collector",
        "func": "var data = flow.get(\"sensorData\") || {};\n\n// Save last update time\ndata.lastUpdate = Date.now();\n\nif (msg.topic === \"home/ldr\") {\n    data.ldr = parseFloat(msg.payload);\n}\n\nif (msg.topic === \"home/pir\") {\n    data.pir = parseInt(msg.payload);\n}\n\nif (msg.topic === \"home/dht\") {\n    let d = typeof msg.payload === \"string\" ? JSON.parse(msg.payload) : msg.payload;\n    data.temp = d.temp;\n    data.humidity = d.hum;\n}\n\nif (msg.topic === \"home/relay\") {\n    data.relay = msg.payload;\n}\n\nflow.set(\"sensorData\", data);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 280,
        "wires": [
            [
                "fb957b29085407da"
            ]
        ]
    },
