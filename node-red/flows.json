    {
        "id": "fb957b29085407da",
        "type": "function",
        "z": "6cc23e5bb2cb7ac2",
        "name": "function",
        "func": "var data = flow.get(\"sensorData\") || {};\n\n// If no recent update → do NOT insert\nif (!data.lastUpdate || (Date.now() - data.lastUpdate) > 10000) {\n    return null;   // stop database write\n}\n\nmsg.topic = `\n    INSERT INTO sensor_data \n    (PIR, LDR, TEMP, HUMIDITY, RELAY)\n    VALUES (?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    data.pir || 0,\n    data.ldr || 0,\n    data.temp || 0,\n    data.humidity || 0,\n    data.relay || \"OFF\"\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 500,
        "wires": [
